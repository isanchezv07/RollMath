---

<div class="relative h-dvh w-screen overflow-hidden bg-zinc-950">
    <canvas
        id="world"
        class="absolute inset-0 h-full w-full touch-none"
    ></canvas>

    <div class="pointer-events-none absolute top-0 left-0 z-20 w-full">
        <slot name="display" />
    </div>
    <div class="absolute bottom-8 left-1/2 z-20 flex -translate-x-1/2 gap-3 pb-[env(safe-area-inset-bottom)]">
        <slot name="controls" />
    </div>
</div>

<script>
    import MatterEngine from "../lib/MatterEngine";
    import { LevelManager } from "../lib/LevelManager";
    import { level1 } from "../levels/level1";
    import { level2 } from "../levels/level2";
    import { level3 } from "../levels/level3";
    import { level4 } from "../levels/level4";
    import { gameBus } from "../lib/GameEventBus";

    const canvas = document.getElementById("world");
    if (canvas) {
        const levelManager = new LevelManager([level1, level2, level3, level4]);
        const engine = new MatterEngine(canvas as HTMLCanvasElement, levelManager);
        engine.start();

        const spawnBtn = document.getElementById("spawn");
        if(spawnBtn) {
            spawnBtn.addEventListener("click", async ()=>{
                await engine.gyro.start();
                engine.spawnBall();
            });
        }

        const miniBtn = document.getElementById("mini");
        if(miniBtn) {
            miniBtn.addEventListener("click", async ()=>{
                await engine.gyro.start();
                engine.spawnMiniBall();
            });
        }

        window.addEventListener("resize", ()=>{
            engine.resize();
        });
    }
</script>